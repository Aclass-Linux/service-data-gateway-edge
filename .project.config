# ── 项目名称 ──────────────────────────────────────────
# 编译产物的命名前缀
ACLASS_PROJECT_NAME=EdgeGateWay

# ── 目标架构 ──────────────────────────────────────────
# x86_64 | armv7
# 对应 cmake/toolchain-{ARCH}.cmake，切换后自动清理重建
ARCH=x86_64

# ── 编译类型 ──────────────────────────────────────────
# Debug   = -O0 -g（调试符号）
# Release = -O3 -DNDEBUG（优化，无调试符号）
# RelWithDebInfo = -O2 -g
# MinSizeRel = -Os
CMAKE_BUILD_TYPE=Debug

# ── 库链接模式 ────────────────────────────────────────
# SHARED = 动态库（.so），发布时需带上 lib/
# STATIC = 静态库（.a），单体二进制部署
# OBJECT = 目标文件（仅编译不打包），符号合入最终目标
# 所有 *_LIB_MODE 变量遵循此规则
ACLASS_LIB_MODE=SHARED

